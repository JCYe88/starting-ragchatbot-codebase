{
  "name": "ragchatbot-frontend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "format": "prettier --write \"*.{html,css,js}\"",
    "format:check": "prettier --check \"*.{html,css,js}\"",
    "lint": "eslint script.js",
    "lint:fix": "eslint --fix script.js",
    "quality": "npm run format:check && npm run lint",
    "quality:fix": "npm run format && npm run lint:fix"
  },
  "devDependencies": {
    "eslint": "^9.27.0",
    "prettier": "^3.5.3"
  }
}
